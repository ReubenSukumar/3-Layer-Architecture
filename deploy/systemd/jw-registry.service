[Unit]
Description=JW Registry Spring Boot API
After=network.target

[Service]
Type=simple
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/jw-registry
EnvironmentFile=/etc/jw-registry/jw-registry.env
ExecStart=/usr/bin/java -jar /opt/jw-registry/app.jar
SuccessExitStatus=143
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
